# .env.example — copy to .env.local and fill in values
# Run: NODE_TLS_REJECT_UNAUTHORIZED=0 vercel env pull .env.local --yes
# (to auto-populate the DATABASE_URL variants from Vercel Neon integration)

# Auto-injected by Vercel Neon Marketplace integration (vercel env pull populates these)
DATABASE_URL=                          # Pooled connection (Pgbouncer) — do NOT use for pgvector
POSTGRES_URL=                          # Alias for DATABASE_URL
POSTGRES_URL_NON_POOLING=              # Direct non-pooled connection — USE THIS for pgvector queries

# Add manually to .env.local AND Vercel dashboard (Settings > Environment Variables)
OPENAI_API_KEY=                        # Required: your OpenAI API key (starts with sk-)
INGEST_SECRET=                         # Required: any strong random string — protects /api/ingest route
                                       # Generate with: openssl rand -base64 32

# NOTE: NODE_TLS_REJECT_UNAUTHORIZED=0 is a shell-only prefix for Vercel CLI commands on Crowe network.
# NEVER add it to this file, .env.local, or Vercel environment variables.
# Doing so would disable TLS verification for all HTTPS calls including OpenAI API.
